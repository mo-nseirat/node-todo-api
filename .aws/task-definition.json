{
    "family": "api-app-task",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::092201262440:role/ecs-task-execution-role",
    "containerDefinitions": [
        {
            "name": "api_app",
            "image": "NODE_TODO_IMAGE",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp"
                }
            ]
        }
    ]
}